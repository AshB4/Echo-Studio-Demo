{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "framework": "express"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "backend/:path*"
    },
    {
      "source": "/:path*",
      "destination": "frontend/:path*"
    }
  ]
}
